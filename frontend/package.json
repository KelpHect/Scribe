{
  "name": "frontend",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "bench": "vitest bench",
    "lint:check": "oxlint . --import-plugin --vitest-plugin --deny-warnings",
    "lint": "oxlint . --import-plugin --vitest-plugin --fix",
    "format": "oxfmt --write \"src/**/*.{ts,js,css}\" \"*.{ts,js}\"",
    "format:check": "oxfmt --check \"src/**/*.{ts,js,css}\" \"*.{ts,js}\""
  },
  "dependencies": {
    "@tanstack/query-core": "^5.100.10",
    "@tanstack/svelte-form": "^1.32.0",
    "@tanstack/svelte-query": "^6.1.29",
    "@tanstack/svelte-virtual": "^3.13.24",
    "@wailsio/runtime": "^3.0.0-alpha.79",
    "lucide-svelte": "^1.0.1",
    "svelte": "^5.55.7",
    "svelte-sonner": "^1.1.1",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/svelte": "^5.0.8",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
